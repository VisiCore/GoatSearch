<form version="1.1" theme="dark" stylesheet="styles/goatsearch.css" script="javascript/goatsearch.js">
  <init>
    <set token="tenantString"></set>
    <set token="workspaceString"></set>
    <set token="pageSizeString"></set>
    <set token="sampleRatioString"></set>
    <set token="queryString"></set>
  </init>
  <search id="preload_tenant">
    <query>
      | savedsearch sysLoadEditTenant key="$loadTenant$"
    </query>
    <done>
      <set token="form.tokenSelectedTenant">$result.tenant$</set>
      <set token="form.tokenSelectedWorkspace">$result.workspace$</set>
    </done>
  </search>
  <label>GoatSearch Explorer</label>
  <fieldset submitButton="false"></fieldset>
  <row>
    <panel>
      <html>
        <p>Welcome to GoatSearch Explorer! Use this view to generate SPL from your Cribl Search KQL and get familiar with the <span class="code">| goatsearch</span> syntax.</p>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <input type="dropdown" token="tokenSelectedTenant">
        <label>Tenant</label>
        <fieldForLabel>tenant</fieldForLabel>
        <fieldForValue>tenant</fieldForValue>
        <search>
          <query>
            | savedsearch sysGetTenantList
          </query>
        </search>
        <change>
          <eval token="tenantString">if (isnull($value$), "", " tenant=\"" + $value$ + "\"")</eval>
        </change>
      </input>
      <input type="text" depends="$hide$" token="loadTenant">
        <label></label>
      </input>
    </panel>
    <panel depends="$tokenSelectedTenant$">
      <input type="dropdown" token="tokenSelectedWorkspace">
        <label>Workspace</label>
        <fieldForLabel>workspace</fieldForLabel>
        <fieldForValue>workspace</fieldForValue>
        <search>
          <query>
            | savedsearch sysGetWorkspaceList tenant="$tokenSelectedTenant$"
          </query>
        </search>
        <default>main</default>
        <change>
          <eval token="workspaceString">if (isnull($value$), "", " workspace=\"" + $value$ + "\"")</eval>
        </change>
      </input>
    </panel>
    <panel>
      <input type="checkbox" token="tokenSelectPageSize">
        <label></label>
        <choice value="set">Change Page Size?</choice>
        <change>
          <set token="pageSizeString"></set>
          <unset token="form.pageSizeValue"></unset>
        </change>
      </input>
      <input type="dropdown" depends="$tokenSelectPageSize$" token="pageSizeValue">
        <label></label>
        <fieldForLabel>display</fieldForLabel>
        <fieldForValue>pageSize</fieldForValue>
        <search>
          <query>| savedsearch sysGeneratePageOptions</query>
        </search>
        <change>
          <eval token="pageSizeString">if (isnull($value$), "", " page=\"" + $value$ + "\"")</eval>
        </change>
      </input>
    </panel>
    <panel>
      <input type="checkbox" token="tokenSelectSampleRatio">
        <label></label>
        <choice value="set">Change Sample Ratio?</choice>
        <change>
          <set token="sampleRatioString"></set>
          <unset token="form.sampleSizeValue"></unset>
        </change>
      </input>
      <input type="dropdown" depends="$tokenSelectSampleRatio$" token="sampleSizeValue">
        <label></label>
        <fieldForLabel>display</fieldForLabel>
        <fieldForValue>sampleFactor</fieldForValue>
        <search>
          <query>| savedsearch sysGenerateSampleOptions</query>
        </search>
        <change>
          <eval token="sampleRatioString">if (isnull($value$), "", " sample=\"" + $value$ + "\"")</eval>
        </change>
      </input>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <label for="csearch_query">Cribl Search Query</label>
        <textarea name="csearch_query" id="csearch_query">dataset="$tokenSelectedDataset$" | limit 1000</textarea>
      </html>
    </panel>
    <panel>
      <input type="time" token="tokenCSearchTime">
        <label>Time Range</label>
        <default>
          <earliest>-15m</earliest>
          <latest>now</latest>
        </default>
      </input>
      <input type="dropdown" token="tokenSelectedDataset" depends="$tokenSelectedTenant$">
        <label>Dataset</label>
        <fieldForLabel>display</fieldForLabel>
        <fieldForValue>id</fieldForValue>
        <search>
          <query>
            | savedsearch sysGetDatasets tenant="$tokenSelectedTenant$" workspace="$tokenSelectedWorkspace$"
          </query>
        </search>
        <default>cribl_internal_logs</default>
      </input>
      <input type="text" depends="$hide$" token="loadTenant">
        <label></label>
      </input>
      <html>
        <p>Time range will be sent to the target time range picker.</p>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Splunk Search Query</title>
      <html>
        <pre id="csearch_string">| goatsearch$tenantString$$workspaceString$$pageSizeString$$sampleRatioString$$queryString$</pre>
        <i class="icon-search-thin search-open" id="csearch_open">
          <span class="tooltiptext tooltip-bottom">Open in Search...</span>
        </i>
      </html>
    </panel>
  </row>
  <row depends="$tokenSelectedTenant$">
    <panel>
      <title>Event Preview</title>
      <html>
        <p>
          Event previews are limited to the last 5 minutes of data for efficiency. If your data are older than 5 minutes, please use the Cribl Search Query above to explore.
        </p>
      </html>
      <event>
        <search>
          <query>
            | savedsearch sysGetSampleEvent tenant="$tokenSelectedTenant$" workspace="$tokenSelectedWorkspace$" dataset="$tokenSelectedDataset$"
          </query>
          <earliest>-5m</earliest>
          <latest>now</latest>
        </search>
      </event>
    </panel>
  </row>
</form>